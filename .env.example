# Platfone API key (required for stdio transport, optional for HTTP if passing x-api-key header)
PLATFONE_API_KEY=your_api_key_here

# Base URL (defaults to production)
# PLATFONE_API_URL=https://temp-number-api.com/api/v1

# Use sandbox for testing (no balance required)
# PLATFONE_API_URL=https://temp-number-api.com/test/api/v1

