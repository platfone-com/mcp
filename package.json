{
  "name": "@platfone/mcp",
  "version": "1.0.2",
  "description": "MCP server for Platfone SMS Activation API",
  "type": "module",
  "bin": {
    "platfone-mcp": "./dist/index.js"
  },
  "main": "./dist/index.js",
  "files": [
    "dist"
  ],
  "repository": {
    "type": "git",
    "url": "git+https://github.com/platfone-com/mcp.git"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  },
  "scripts": {
    "build": "tsc",
    "dev:stdio": "tsx src/index.ts --transport=stdio",
    "dev:http": "tsx src/index.ts --transport=http --port=3000",
    "start": "node dist/index.js",
    "start:http": "node dist/index.js --transport=http",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "keywords": [
    "mcp",
    "platfone",
    "sms",
    "activation"
  ],
  "license": "MIT",
  "author": "Platfone <support@platfone.com> (https://platfone.com)",
  "homepage": "https://github.com/platfone-com/mcp#readme",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.27.1",
    "dotenv": "^17.3.1",
    "express": "^4.21.0",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/express": "^5.0.0",
    "@types/node": "^22.0.0",
    "prettier": "^3.8.1",
    "tsx": "^4.19.0",
    "typescript": "^5.7.0"
  }
}
